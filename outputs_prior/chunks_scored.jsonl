{"start": 232.0, "end": 238.0, "text": "That's definitely been a positive surprise.", "sentiment": "POSITIVE", "score": 0.9998551607131958, "signed_score": 0.9998551607131958, "positive_prob": 0.9998551607131958, "negative_prob": 0.00014483928680419922}
