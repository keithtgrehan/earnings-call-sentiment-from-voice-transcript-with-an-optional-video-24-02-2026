{"start": 142.0, "end": 145.0, "text": "And we're going to throw in many different things.", "sentiment": "POSITIVE", "score": 0.9977105855941772, "signed_score": 0.9977105855941772, "positive_prob": 0.9977105855941772, "negative_prob": 0.002289414405822754}
