{"start": 198.0, "end": 202.0, "text": "We can bring both the creators and just modify itself with that strategy.", "sentiment": "NEGATIVE", "score": 0.8350642919540405, "signed_score": -0.8350642919540405, "positive_prob": 0.16493570804595947, "negative_prob": 0.8350642919540405}
