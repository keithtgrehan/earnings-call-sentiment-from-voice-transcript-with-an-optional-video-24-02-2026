{"start": 116.0, "end": 119.0, "text": "We also anticipate a gross margin of 26 million.", "sentiment": "NEGATIVE", "score": 0.970499575138092, "signed_score": -0.970499575138092, "positive_prob": 0.02950042486190796, "negative_prob": 0.970499575138092}
{"start": 119.0, "end": 122.0, "text": "And an operating profit of 180 million.", "sentiment": "POSITIVE", "score": 0.9967418313026428, "signed_score": 0.9967418313026428, "positive_prob": 0.9967418313026428, "negative_prob": 0.0032581686973571777}
