{"start": 133.0, "end": 138.0, "text": "We also expect our free cash flow generation to meaningfully exceed what we generated in 2023.", "sentiment": "POSITIVE", "score": 0.9633710980415344, "signed_score": 0.9633710980415344, "positive_prob": 0.9633710980415344, "negative_prob": 0.036628901958465576}
