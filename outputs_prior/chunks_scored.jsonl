{"start": 244.0, "end": 246.0, "text": "So I feel really good about that.", "sentiment": "POSITIVE", "score": 0.9998586177825928, "signed_score": 0.9998586177825928, "positive_prob": 0.9998586177825928, "negative_prob": 0.00014138221740722656}
